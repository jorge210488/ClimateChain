{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": ["error", ">=0.8.24 <0.9.0"],
    "reason-string": "off",
    "func-visibility": ["error", { "ignoreConstructors": true }],
    "ordering": "error",
    "max-line-length": "off",
    "use-natspec": "error",
    "gas-indexed-events": "off",
    "gas-strict-inequalities": "error"
  }
}
